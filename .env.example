# ============================================================================
# WMS (Warehouse Management System) Configuration File
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# 3. Update all values below with your settings
# 4. NEVER commit .env file to git!
#
# ============================================================================

# ================================
# SECRET KEY (REQUIRED!)
# ================================
# Flask secret key for session encryption
# ⚠️  MUST be set! Application will not start without it
# ⚠️  Use different keys for dev/staging/production
# ⚠️  Never use the example value below!
#
# Generate using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-random-key-here-please-change-this

# ================================
# DATABASE
# ================================
# SQLite database file path (relative or absolute)
# Default: data.db (in project root)
DATABASE_PATH=data.db

# ================================
# BACKUP
# ================================
# Directory for database backups
# Backups are created automatically every 6 hours (if cron is setup)
# Retention: 30 days
BACKUP_DIR=backups

# ================================
# ADMIN USER (Bootstrap)
# ================================
# Default admin account created automatically on first run (if no users exist)
#
# Username for the admin account
ADMIN_USERNAME=admin

# Admin password (OPTIONAL)
# - Leave EMPTY to auto-generate a secure random password
# - If empty, password will be displayed in console ONCE on first run
# - You MUST change this password after first login for security
# - Only used for initial setup (ignored if users already exist)
ADMIN_DEFAULT_PASSWORD=

# ================================
# POS INTEGRATION (Optional)
# ================================
# Configure these if you want to sync dispatch data back to POS system
#
# POS API endpoint (e.g., https://your-pos-system.com/api)
POS_API_URL=

# POS API authentication key/token
POS_API_KEY=

# ================================
# SESSION
# ================================
# User session timeout in minutes
# Default: 480 minutes (8 hours)
SESSION_TIMEOUT=480

# ================================
# LOGGING
# ================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=server.log

# ================================
# APPLICATION
# ================================
# Application display name
APP_NAME=VNIX Order Management

# Flask environment (development/production)
# FLASK_ENV=production
